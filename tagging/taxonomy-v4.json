      "values": [
        { "value": "timeline-animation-editor", "description": "Core animation creation/editing/playback. AcidBubbles' Timeline and variants." },
        { "value": "pose-ik-helper",            "description": "Static posing, pose loading/saving, IK targeting, controller adjustment." },
        { "value": "bone-control",              "description": "Direct bone manipulation (distinct from controller-level IK)." },
        { "value": "puppeteer-controller",      "description": "Character animation/control framework distinct from Timeline (e.g. Puppeteer, idle posing systems)." },
        { "value": "object-tracking",           "description": "Rotates or moves objects to follow/face/align with targets. General object aiming." },
        { "value": "parameter-randomizer",      "description": "Randomizes morph/parameter values across atoms or expressions." },
        { "value": "scene-logic-triggers",      "description": "State machines, conditional triggers, logic bricks, delay-and-fire, sequence choices." },

        { "value": "gaze-eye-tracking",         "description": "Eye-tracking and gaze direction. Glance and similar." },
        { "value": "first-person-embodiment",   "description": "VR comfort and first-person body ownership. Embody and similar." },
        { "value": "pov-improvement",           "description": "Camera/POV enhancements." },

        { "value": "post-processing-effects",   "description": "Camera-level visual effects: bloom, DOF, AA, vignette, motion blur, LUT." },
        { "value": "high-res-screenshot",       "description": "Supersampled stills, enhanced renders. SuperShot family." },
        { "value": "vr-rendering",              "description": "VR180/360 stereo image/video rendering and BVH export." },
        { "value": "asset-property-editor",     "description": "Per-CUA / per-light property editing (scale, shadows, material color, alpha, emission, render settings)." },

        { "value": "physics-genital",           "description": "Genital physics (male, female, futa): alignment, thrust, anus/labia automation, foreskin control. REPLACES v3 genital-physics-control." },
