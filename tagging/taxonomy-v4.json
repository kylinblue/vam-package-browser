        { "value": "audio-lipsync",             "description": "Mouth animation morphs driven by audio. NARROWED in v4 — file management/sound effects go to audio-management or audio-sfx." },
        { "value": "audio-management",          "description": "Audio file importing/organizing/triggering, soundtrack synchronization." },
        { "value": "audio-sfx",                 "description": "Triggered sound effects: moans, slaps, ambient hits. VAMMoan, EasyMoan, SlapStuff family." },
        { "value": "audio-visualization",       "description": "Audio frequency analysis or beat-driven trigger output (without playback management)." },

        { "value": "expression-facial-triggers","description": "Facial expression control, emotion triggers. GRADUATED from v3 speculative." },
        { "value": "body-language",             "description": "Comprehensive character behavior systems (arousal, breathing, body language meta-frameworks). MacGruber Life and similar." },
        { "value": "belly-bulge",               "description": "Insertion-driven belly bulge morphs and physics." },
        { "value": "oral-sex-animation",        "description": "Blowjob/deepthroat animation with optional audio." },

