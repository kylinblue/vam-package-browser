{
  "version": "v4",
  "summary": "Multi-dimensional namespaced taxonomy for VaM packages. Every family receives exactly one `kind:*` tag identifying its primary identity, plus 0-N tags from other namespaces describing attributes. Replaces v3's flat tag list + out-of-scope binary; everything gets tagged.",

  "namespaces": {

    "kind": {
      "applies_to": "any",
      "cardinality": "exactly-1",
      "description": "Primary identity of the package. Required on every record. Decided from description + instructions + content_summary, NOT from the input package_type heuristic which is unreliable.",
      "values": [
        { "value": "utility-plugin",   "description": "Tools that modify VaM behavior, add capabilities, or fix issues. Plugins, scripts, session helpers." },
        { "value": "location-scene",   "description": "Reusable environments/backdrops. CUA-dominant, no significant animation, no Person customization driving the package." },
        { "value": "act-scene",        "description": "Animation-heavy narrative or sex scenes. One-off content, often with Timeline/triggers driving choreography." },
        { "value": "character-look",   "description": "Character appearance packs (any style, any gender). Includes Wunderwise-pattern Looks shipped with a demo scene — kind is determined by primary purpose, not bundling." },
        { "value": "clothing-item",    "description": "Clothing items or packs. Includes decals, geoshells, and accessories that present as clothing." },
        { "value": "hair-item",        "description": "Hair items or packs. Includes scalp hair, body hair, beard, eyelashes." },
        { "value": "morph-pack",       "description": "Morph collections. Face/body/genital/limb adjustments." },
        { "value": "pose-preset",      "description": "Pose preset(s). Single or multi-character." },
        { "value": "prop-asset",       "description": "Standalone furniture, vehicles, weapons, decorative objects. Generally usable in any scene." },
        { "value": "support-asset",    "description": "Non-playable assets: LUTs, lighting rigs, water planes, skyboxes, particle effects, texture libraries. Used by other tools." },
        { "value": "texture-pack",     "description": "Pure texture distributions: skin variants, eye textures, decal libraries, makeup, tattoos, normal maps." },
        { "value": "audio-pack",       "description": "Raw audio file packs: music, sound effects, moans, voice clips, ambient." },
        { "value": "subscene-pack",    "description": "Modular reusable scene chunks: lighting subscenes, prop bundles, character pose sets." },
        { "value": "mixed-package",    "description": "Genuinely multi-purpose package spanning several kinds with no single dominant identity. Rare; explain in notes." }
      ]
    },

    "content": {
      "applies_to": ["act-scene"],
      "cardinality": "exactly-1",
      "description": "Content rating for act scenes. Required on kind:act-scene; not used elsewhere.",
      "values": [
        { "value": "safe",        "description": "No sexual or suggestive content." },
        { "value": "suggestive",  "description": "Suggestive or partially nude but not explicit." },
        { "value": "explicit",    "description": "Sexual acts depicted." }
      ]
    },

    "count": {
      "applies_to": ["pose-preset", "act-scene"],
      "cardinality": "0-1",
      "description": "Number of participants.",
      "values": [
        { "value": "single", "description": "One person." },
        { "value": "duo",    "description": "Two people." },
        { "value": "group",  "description": "Three or more." }
      ]
    },

    "function": {
      "applies_to": ["utility-plugin"],
