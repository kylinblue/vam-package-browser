        { "value": "clothing-mesh-editor",      "description": "Clothing mesh visualization, rewraps, sim cloth editing." },
        { "value": "clothing-texture-manager",  "description": "Wardrobe-style outfit/texture swapping at runtime." },
        { "value": "emissive-clothing-effect",  "description": "Emissive shader effects on clothing items with color tween/alpha pulse." },
        { "value": "clothing-favorites",        "description": "Favorite-tagging and quick filtering for clothing/hair libraries." },
        { "value": "static-clothing-converter", "description": "Convert dynamic clothing to static parented meshes." },

        { "value": "hair-specific-tools",       "description": "Hair styling/editor/preset tools. GRADUATED from v3 speculative." },

        { "value": "package-dependency-manager","description": "Scan loaded scenes for missing .var deps and assist locating/downloading." },
        { "value": "addon-updater",             "description": "Auto-update installed addons/plugins." },
        { "value": "ui-enhancement-toolkit",    "description": "UI extension: canvas buttons, quick-access widgets, performance HUDs, workflow tools." },
        { "value": "session-plugin-manager",    "description": "Session-level plugin/preset management and auto-loading." }
