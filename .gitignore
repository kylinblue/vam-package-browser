# ---------------------------------------------------------------------------
# Build outputs — Rust + Vite/TS
# ---------------------------------------------------------------------------
src-tauri/target/
src-tauri/gen/
**/*.rs.bk
dist/
.vite/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/

# ---------------------------------------------------------------------------
# Local model / data caches (re-downloadable; do NOT commit)
# ---------------------------------------------------------------------------
# fastembed downloads ONNX models on first use; ~600 MB per location.
# Matches both ./.fastembed_cache/ and ./src-tauri/.fastembed_cache/.
.fastembed_cache/

# ---------------------------------------------------------------------------
# Local-only sampling/review output — regenerated on demand from the DB by
# src-tauri/src/bin/sample_predictions.rs. Contents are user-specific.
# ---------------------------------------------------------------------------
classifier-review-sample.md

# ---------------------------------------------------------------------------
# Personal-library data — audit CSVs and tagging samples/prompts are derived
# from the local .var collection and stay out of the public repo.
# (tagging/taxonomy-*.json stays tracked — it's configuration, not data.)
# ---------------------------------------------------------------------------
docs/audits/
tagging/calibration/
tagging/pilot/
tagging/pilot-v4/

# ---------------------------------------------------------------------------
# Environment files (allow example template through)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# IDE / editor (defensive — none present today)
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

